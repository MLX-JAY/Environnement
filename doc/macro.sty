\newcommand {\fig} [5] {
	\begin{figure} [htbp]
		\begin{center}
          \includegraphics[width=#2]{#1}
			\caption{#4}
			\label {fig:#5}
		\end{center}
	\end{figure}
}

\newcommand {\noreffig} [3] {
	\begin{figure} [htbp]
		\begin{center}
          \includegraphics[width=#2]{#1}
		\end{center}
	\end{figure}
}
